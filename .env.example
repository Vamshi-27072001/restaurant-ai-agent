# =============================================================
# Taco Bell UK AI Chatbot — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# =============================================================

# --- OpenAI ---
# Used by: OpenAI Chat Model node, OpenAI Embeddings node
OPENAI_API_KEY=sk-your-openai-api-key-here

# --- Google Sheets ---
# Used by: Menu Items Tool, Nutrition Information Tool, Save to Customer Interactions
# OAuth2 credentials are managed inside n8n — set up via:
# Settings > Credentials > Google Sheets OAuth2 API
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# --- Google Spreadsheet IDs ---
# Menu spreadsheet (contains "UK Menu Items" and "Nutrition (UK)" sheets)
MENU_SPREADSHEET_ID=your-taco-bell-menu-spreadsheet-id

# Customer interactions log spreadsheet
INTERACTIONS_SPREADSHEET_ID=your-customer-interactions-spreadsheet-id

# --- n8n Instance ---
N8N_INSTANCE_URL=https://your-instance.app.n8n.cloud
N8N_API_KEY=your-n8n-api-key
