# n8n Instance
N8N_API_URL=https://your-instance.app.n8n.cloud
N8N_API_KEY=your_n8n_api_key_here

# OpenAI (used for Chat Model + Embeddings)
OPENAI_API_KEY=sk-your_openai_api_key_here

# Google Sheets OAuth2 (configure via n8n Credentials UI)
# Google Client ID and Secret are set up inside n8n — not as env vars.
# See README for setup instructions.

# Google Sheet IDs (find in the sheet URL)
MENU_GOOGLE_SHEET_ID=your_taco_bell_menu_sheet_id_here
CONVERSATIONS_GOOGLE_SHEET_ID=your_customer_interactions_sheet_id_here
